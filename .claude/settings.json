{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [{ "type": "command", "command": "node .lore/harness/hooks/session-init.js" }]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [{ "type": "command", "command": "node .lore/harness/hooks/prompt-preamble.js" }]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Read",
        "hooks": [{ "type": "command", "command": "node .lore/harness/hooks/protect-memory.js" }]
      },
      {
        "matcher": "Write",
        "hooks": [{ "type": "command", "command": "node .lore/harness/hooks/context-path-guide.js" }],
        "description": "Guide writes to docs/context/"
      },
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": "node .lore/harness/hooks/rule-guard.js" }],
        "description": "Reinforce rules based on target file path"
      },
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": "node .lore/harness/hooks/harness-guard.js" }],
        "description": "Warn when writing to harness-owned files"
      },
      {
        "matcher": "Read|Glob",
        "hooks": [{ "type": "command", "command": "node .lore/harness/hooks/search-guard.js" }],
        "description": "Nudge to use semantic search instead of speculative reads"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [{ "type": "command", "command": "node .lore/harness/hooks/knowledge-tracker.js || true" }]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [{ "type": "command", "command": "node .lore/harness/hooks/knowledge-tracker.js || true" }]
      }
    ]
  }
}
