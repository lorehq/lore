{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [{ "type": "command", "command": "node .lore/harness/hooks/session-init.js" }]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": "node .lore/harness/hooks/prompt-preamble.js" }]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "read_file|grep_search",
        "hooks": [{ "type": "command", "command": "node .lore/harness/hooks/protect-memory.js" }]
      },
      {
        "matcher": "write_file|replace",
        "hooks": [
          { "type": "command", "command": "node .lore/harness/hooks/harness-guard.js" }
        ]
      },
      {
        "matcher": "read_file|glob",
        "hooks": [{ "type": "command", "command": "node .lore/harness/hooks/search-guard.js" }]
      }
    ],
    "AfterTool": [
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": "node .lore/harness/hooks/memory-nudge.js || true" }]
      }
    ]
  },
  "mcp": {
    "mcpServers": {
      "lore": {
        "command": "node",
        "args": [".lore/harness/mcp/lore-server.js"]
      }
    }
  }
}
